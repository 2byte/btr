{
  "name": "browser-tracker",
  "version": "1.0.0",
  "description": "Browser extension builder for multiple browsers",
  "scripts": {
    "build": "bun run build.ts",
    "build:firefox-dev": "bun run build.ts firefox-dev",
    "build:firefox-prod": "bun run build.ts firefox-prod",
    "build:chrome-dev": "bun run build.ts chrome-dev",
    "build:chrome-prod": "bun run build.ts chrome-prod",
    "build:opera-dev": "bun run build.ts opera-dev",
    "build:opera-prod": "bun run build.ts opera-prod",
    "pack": "bun run pack.ts",
    "build:pack": "bun run build && bun run pack",
    "clean": "rm -rf dist packed",
    "install:chrome-extension": "bun run serverVideoCapture/install_chrome_extension.ts"
  },
  "dependencies": {
    "@types/bun": "^1.3.8",
    "fs-extra": "^11.3.3",
    "graceful-fs": "^4.2.11",
    "lodash": "^4.17.23",
    "puppeteer": "^21.11.0"
  }
}