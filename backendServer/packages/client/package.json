{
  "name": "@comeback/client",
  "version": "1.0.0",
  "type": "module",
  "description": "Remote agent client for Comeback server — attaches to a RemoteServer over WebSocket and exposes terminal + filesystem access",
  "scripts": {
    "comebackCli": "bun ./src/cli/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "comebackCli": "./src/cli/cli.ts",
    "comeback-client": "./src/client.ts"
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "bun-pty": "^0.4.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
