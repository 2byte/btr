# Example .env configuration for RemoteServer
# Copy this file to .env and customize

# Server configuration
REMOTE_SERVER_PORT=8013
REMOTE_SERVER_HOST=0.0.0.0

# Client WebSocket URL
WS_URL=ws://localhost:8013

# ==========================================
# Authentication (IMPORTANT!)
# ==========================================

# Single token (for one client)
# Generate with: bun generate-token.ts
# API_TOKEN=your-secure-token-here

# Multiple tokens (comma-separated, for multiple clients)
# Generate with: bun generate-token.ts --count 3
# API_TOKENS=token1,token2,token3

# ==========================================
# Security Recommendations
# ==========================================

# 1. Always use SECURE tokens (64+ characters)
# 2. NEVER commit tokens to git (add .env to .gitignore)
# 3. Generate tokens with: bun generate-token.ts
# 4. Rotate tokens regularly
# 5. Use separate tokens for each client
# 6. In production, use WSS (secure WebSocket)

# ==========================================
# Example tokens (DO NOT USE IN PRODUCTION)
# ==========================================

# Example 1: Single client
# API_TOKEN=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456

# Example 2: Multiple clients
# API_TOKENS=client1token123456789012345678901234567890abcdef12345678,client2token234567890123456789012345678901234567890abcdef,client3token345678901234567890123456789012345678901234567890

# To generate real tokens:
# bun generate-token.ts --count 3
